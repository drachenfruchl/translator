		{
			"Name": "cv_translator_targetLanguage",
			"DefaultValue": "en",
			"Flags": 16777232
		},
		{
			"Name": "cv_translator_ignoredLanguages",
			"DefaultValue": "en,ny,sw,alz,ms,haw,cnh,tl,hi,ht,so,la,id",
